APP_NAME=infonih
DEBUG=false
LOG_LEVEL=INFO

# Postgres
# - Local dev (workers run on the host, Postgres in docker): use localhost
# - VPS / docker compose (workers run in containers on the same network): use `postgres` (the service name)
DATABASE_URL=postgresql+asyncpg://infonih:infonih@localhost:5432/infonih
TEST_DATABASE_URL=postgresql+asyncpg://infonih:infonih@localhost:5432/infonih_test

# Ingestion defaults (per-source values override these in the DB)
DEFAULT_POLL_INTERVAL_MINUTES=60

# LLM
ANTHROPIC_API_KEY=sk-ant-...
SCORE_MODEL=claude-haiku-4-5
SUMMARIZE_MODEL=claude-haiku-4-5
SCORE_BATCH_SIZE=20
SCORE_INTERVAL_MINUTES=5

# Digest
DIGEST_MAX_ITEMS=7
SCORE_THRESHOLD=50
# How far back to look for fresh articles. 24h is the steady-state value;
# bump higher (e.g. 168 = 7 days) while bootstrapping a new install with
# mostly-old backfill content, then lower it once fresh articles flow in.
DIGEST_WINDOW_HOURS=24
DIGEST_TIME_LOCAL=07:00
DIGEST_TIMEZONE=Asia/Jakarta

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
